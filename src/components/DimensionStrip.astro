---
const dimensions = [
  {
    name: 'Build',
    descriptor: 'From zero to certified payment gateway — products that scale.',
    tagClass: 'bg-dim-build-bg text-dim-build-text',
  },
  {
    name: 'Fix',
    descriptor: 'Diagnosing root cause and turning product debt into momentum.',
    tagClass: 'bg-dim-fix-bg text-dim-fix-text',
  },
  {
    name: 'Design',
    descriptor: 'Data-led product thinking for AI-native features.',
    tagClass: 'bg-dim-design-bg text-dim-design-text',
  },
  {
    name: 'Transform & Teach',
    descriptor: 'Embedding agile at the organization level, not just the team.',
    tagClass: 'bg-dim-teach-bg text-dim-teach-text',
  },
] as const;
---

<section class="py-16 md:py-20 border-t border-border">
  <div class="max-w-content mx-auto px-6">
    <h2 class="font-tight font-medium text-xl text-ink-secondary mb-8">What I do</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        dimensions.map((dim) => (
          <a
            href={`/portfolio?dimension=${encodeURIComponent(dim.name)}`}
            class="group block p-6 bg-surface rounded-card border border-border hover:border-accent hover:-translate-y-0.5 transition-all duration-200"
          >
            <span
              class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium mb-4 ${dim.tagClass}`}
            >
              {dim.name}
            </span>
            <p class="text-sm text-ink-secondary leading-relaxed group-hover:text-ink-primary transition-colors">
              {dim.descriptor}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
