---
const udemy = 'https://www.udemy.com/course/beginners-guide-to-agile-software-transformation/?referralCode=0B4C745169156D1463FE';
---

<section class="py-8 md:py-10 border-t border-border">
  <div class="max-w-content mx-auto px-6">
    <div class="bg-surface rounded-card border border-border px-8 py-8 md:px-12 md:py-10 flex flex-col md:flex-row md:items-center md:justify-between gap-8">

      <!-- Text block -->
      <div>
        <p class="text-xs font-medium text-accent uppercase tracking-widest mb-3">Teaching</p>
        <h2 class="font-tight font-medium text-3xl md:text-4xl text-ink-primary tracking-tight leading-none mb-3">
          Nearly 5,000 learners
        </h2>
        <p class="text-lg text-ink-secondary leading-relaxed max-w-xl">
          have taken my agile-transformation course. I teach what I practice.
        </p>
      </div>

      <!-- CTA -->
      <div class="shrink-0">
        <a
          href={udemy}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 bg-accent text-white font-medium rounded-full text-sm hover:bg-accent-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          View the course ↗
        </a>
      </div>

    </div>
  </div>
</section>
