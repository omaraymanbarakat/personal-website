---
const navLinks = [
  { label: 'Work', href: '/portfolio' },
  { label: 'About', href: '/about' },
  { label: 'Résumé', href: '/resume' },
  { label: 'Cover Letter', href: '/cover-letter' },
  { label: 'Contact', href: '/#contact' },
] as const;
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-sm border-b border-border">
  <nav
    class="max-w-content mx-auto px-6 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="font-tight font-medium text-base text-ink-primary hover:text-accent transition-colors"
    >
      Omar A. Barakat
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-ink-secondary hover:text-ink-primary transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 -mr-2 text-ink-secondary hover:text-ink-primary transition-colors rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
    >
      <svg
        id="icon-open"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        viewBox="0 0 24 24"
        class="hidden"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-surface"
    role="region"
    aria-label="Mobile navigation"
  >
    <ul class="px-6 py-4 space-y-1" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block text-sm font-medium text-ink-secondary hover:text-ink-primary transition-colors py-2"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
