---
import settings from '../data/settings.json';
const credentials = [
  { label: 'IBM AI PM', url: 'https://www.coursera.org/account/accomplishments/specialization/5QLR5TY01FRS' },
  { label: 'ICP-ACC',   url: 'https://www.icagile.com/credentials/c4ea589b-dbba-46d0-ad09-4bebdfea808b' },
  { label: 'PSM I',     url: 'https://scrum.org/certificates/459963' },
];
---

<section class="pt-12 pb-20 md:pt-32 md:pb-28 max-w-content mx-auto px-6">
  <div class="flex flex-col-reverse md:flex-row md:items-start md:justify-between md:gap-16">

    <!-- Text content -->
    <div class="max-w-2xl">
      <h1
        class="font-tight font-medium text-5xl md:text-6xl lg:text-7xl text-ink-primary tracking-tight leading-none mb-4"
      >
        Omar A. Barakat
      </h1>

      <p class="text-lg md:text-xl text-accent font-medium mb-6">
        Technical Product Manager · Agile Coach
      </p>

      <p class="text-lg md:text-xl text-ink-secondary leading-relaxed mb-8">
        10 years across tech, management, and training. I build products and the systems behind
        them, fix ones that have broken down, design for hard problems with no obvious answer, and
        transform how organizations ship.
      </p>

      <!-- Four-verb tagline -->
      <div
        class="flex flex-wrap gap-2 mb-8"
        aria-label="Core disciplines"
      >
        {[
          { label: 'Build',              href: '#what-i-do' },
          { label: 'Fix',               href: '#what-i-do' },
          { label: 'Design',            href: '#what-i-do' },
          { label: 'Transform & Teach', href: '#what-i-do' },
        ].map(({ label, href }) => (
          <a
            href={href}
            class="font-tight font-medium text-sm text-ink-primary inline-flex items-center px-3 py-1.5 rounded-full border border-border hover:border-accent hover:bg-accent-light hover:text-accent active:bg-accent active:text-white active:border-accent transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Credential strip -->
      <div class="flex flex-wrap gap-2 mb-10">
        {
          credentials.map((cred) => (
            <a
              href={cred.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative inline-block px-3 py-1 bg-accent-light text-accent text-xs font-medium rounded-full hover:bg-accent hover:text-white transition-colors"
            >
              {cred.label}
              <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-ink-primary px-2 py-1 text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity">
                View Credential
              </span>
            </a>
          ))
        }
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="/portfolio"
          class="inline-flex items-center px-6 py-3 bg-accent text-white font-medium rounded-full text-sm hover:bg-accent-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          View work
        </a>
        <a
          href="/resume"
          class="inline-flex items-center px-6 py-3 bg-transparent text-ink-primary font-medium rounded-full text-sm border border-border hover:border-ink-secondary transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink-primary"
        >
          Résumé
        </a>
      </div>
    </div>

    <!-- Headshot -->
    <div class="mb-10 md:mb-0 shrink-0">
      <div class="relative w-32 h-32 md:w-44 md:h-44 mx-auto md:mx-0">
        <div class="absolute inset-0 rounded-full scale-110 opacity-15 bg-accent"></div>
        <img
          src={settings.heroImage}
          alt="Omar A. Barakat"
          width="176"
          height="176"
          class="relative w-full h-full rounded-full object-cover object-top border border-border"
        />
      </div>
    </div>

  </div>
</section>
