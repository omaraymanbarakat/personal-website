---
const year = new Date().getFullYear();

const footerLinks = [
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Résumé', href: '/resume' },
  { label: 'Cover Letter', href: '/cover-letter' },
  { label: 'Contact', href: '/#contact' },
];
---

<footer class="border-t border-border bg-surface">
  <div class="max-w-content mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <p class="font-tight font-medium text-ink-primary">Omar A. Barakat</p>
        <p class="text-sm text-ink-secondary mt-0.5">Technical Product Manager · Agile Coach</p>
      </div>
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-2" role="list">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-ink-secondary hover:text-ink-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-8 pt-6 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
    >
      <p class="text-xs text-ink-secondary">© {year} Omar A. Barakat</p>
      <div class="flex items-center gap-5">
        <a
          href="mailto:omarbravotube@gmail.com"
          class="text-xs text-ink-secondary hover:text-accent transition-colors"
        >
          omarbravotube@gmail.com
        </a>
        <a
          href="https://www.linkedin.com/in/omaraymanbarakat/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-ink-secondary hover:text-accent transition-colors"
        >
          LinkedIn ↗
        </a>
      </div>
    </div>
  </div>
</footer>
