---
type Dimension = 'Build' | 'Fix' | 'Design' | 'Transform & Teach';

interface Props {
  title: string;
  dimension: Dimension;
  hook: string;
  metric: string;
  demonstrates: string;
  href: string;
  external?: boolean;
}

const { title, dimension, hook, metric, demonstrates, href, external = false } = Astro.props;

const dimTag: Record<Dimension, string> = {
  Build: 'bg-dim-build-bg text-dim-build-text',
  Fix: 'bg-dim-fix-bg text-dim-fix-text',
  Design: 'bg-dim-design-bg text-dim-design-text',
  'Transform & Teach': 'bg-dim-teach-bg text-dim-teach-text',
};
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group flex flex-col bg-surface rounded-card border border-border p-6 hover:border-accent hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200"
  data-dimension={dimension}
>
  <div class="flex items-start justify-between gap-4 mb-4">
    <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${dimTag[dimension]}`}>
      {dimension}
    </span>
    {external && <span class="text-ink-secondary text-sm leading-none mt-0.5" aria-label="Opens externally">↗</span>}
  </div>

  <h3
    class="font-tight font-medium text-base text-ink-primary mb-2 group-hover:text-accent transition-colors leading-snug flex-1"
  >
    {title}
  </h3>

  <p class="text-sm text-ink-secondary leading-relaxed mb-5">
    {hook}
  </p>

  <div class="flex items-center justify-between gap-2 pt-4 border-t border-border mt-auto">
    <span class="text-xs font-medium text-accent">{metric}</span>
    <span class="text-xs text-ink-secondary">{demonstrates}</span>
  </div>
</a>
