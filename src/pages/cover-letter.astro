---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'cover-letter');
const { Content } = await entry.render();
---

<BaseLayout
  title="Cover Letter"
  description="Omar A. Barakat — a note on how I work and what I build."
>
  <div class="max-w-reading mx-auto px-6 py-12 md:py-16 print:py-8 print:px-0">

    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-12 pb-8 border-b border-border">
      <div>
        <h1 class="font-tight font-medium text-3xl md:text-4xl text-ink-primary mb-1">
          Cover letter
        </h1>
        <p class="text-sm text-ink-secondary">A note on how I work and what I build.</p>
      </div>
      <a
        href="https://docs.google.com/document/d/1cvmRvdNN1xrX55ihFig4Fu336HzFZB-v-xVm-udvL1E/export?format=pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white font-medium rounded-full text-sm hover:bg-accent-dark transition-colors shrink-0 self-start print:hidden"
      >
        ↓ Download PDF
      </a>
    </header>

    <!-- Letter body -->
    <div class="prose-cover-letter">
      <Content />
    </div>

    <!-- Signature -->
    <div class="mt-10 pt-8 border-t border-border">
      <p class="text-ink-primary font-medium mb-1">— Omar Barakat</p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ink-secondary">
        <a
          href="mailto:omarbravotube@gmail.com"
          class="hover:text-accent transition-colors"
        >
          omarbravotube@gmail.com
        </a>
        <a
          href="https://www.linkedin.com/in/omaraymanbarakat/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-accent transition-colors"
        >
          LinkedIn ↗
        </a>
      </div>
    </div>

    <!-- Bottom CTAs -->
    <div class="mt-10 pt-8 border-t border-border flex flex-wrap gap-4 print:hidden">
      <a
        href="/portfolio"
        class="text-sm font-medium text-accent hover:text-accent-dark transition-colors"
      >
        View my work →
      </a>
      <a
        href="/resume"
        class="text-sm font-medium text-ink-secondary hover:text-ink-primary transition-colors"
      >
        Résumé →
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .prose-cover-letter :global(p) {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary, #5A5A57);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .prose-cover-letter :global(p:last-child) {
    margin-bottom: 0;
  }

  @media print {
    :global(header),
    :global(footer) {
      display: none !important;
    }
  }
</style>
