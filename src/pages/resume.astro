---
import BaseLayout from '../layouts/BaseLayout.astro';
import resume from '../data/resume.json';

const { summary, experience, earlier, certifications, awards, skills, tools, selectedProducts, educationDegree, educationInstitution, languages } = resume;

const credentialUrls: Record<string, string> = {
  'IBM AI Product Manager': 'https://www.coursera.org/account/accomplishments/specialization/5QLR5TY01FRS',
  'ICP-ACC (Agile Coaching)': 'https://www.icagile.com/credentials/c4ea589b-dbba-46d0-ad09-4bebdfea808b',
  'PSM I — 98.8%': 'https://scrum.org/certificates/459963',
};
---

<BaseLayout
  title="Résumé"
  description="Omar A. Barakat — Technical Product Manager & Agile Coach. 10+ products shipped, 5+ companies transformed."
>
  <div class="max-w-reading mx-auto px-6 py-12 md:py-16 print:py-8 print:px-0">

    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-10 pb-8 border-b border-border print:mb-6 print:pb-6">
      <div>
        <h1 class="font-tight font-medium text-3xl md:text-4xl text-ink-primary mb-1">
          Omar A. Barakat
        </h1>
        <p class="text-ink-secondary text-base mb-1">Technical Product Manager · Agile Coach</p>
        <p class="text-xs text-ink-secondary">
          <a href="https://www.coursera.org/account/accomplishments/specialization/5QLR5TY01FRS" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors underline underline-offset-2 decoration-border hover:decoration-accent">IBM AI Product Manager</a>
          ·
          <a href="https://www.icagile.com/credentials/c4ea589b-dbba-46d0-ad09-4bebdfea808b" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors underline underline-offset-2 decoration-border hover:decoration-accent">ICP-ACC</a>
          ·
          <a href="https://scrum.org/certificates/459963" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors underline underline-offset-2 decoration-border hover:decoration-accent">PSM I (98.8%)</a>
        </p>
        <p class="text-sm text-ink-secondary mt-2">
          Cairo, Egypt ·
          <a href="mailto:omarbravotube@gmail.com" class="hover:text-accent transition-colors">
            omarbravotube@gmail.com
          </a>
          ·
          <a
            href="https://www.linkedin.com/in/omaraymanbarakat/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent transition-colors"
          >
            LinkedIn
          </a>
        </p>
      </div>
      <a
        href="https://docs.google.com/document/d/1IuVtx0s008Xj1LOnlm4w9_JUpSzN0Q59yjgsBIeLXBo/export?format=pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white font-medium rounded-full text-sm hover:bg-accent-dark transition-colors shrink-0 self-start print:hidden"
      >
        ↓ Download PDF
      </a>
    </header>

    <!-- Summary -->
    <section class="mb-10">
      <h2 class="resume-section-heading">Summary</h2>
      <p class="text-sm text-ink-secondary leading-relaxed">{summary}</p>
    </section>

    <!-- Experience -->
    <section class="mb-10">
      <h2 class="resume-section-heading">Experience</h2>
      <div class="space-y-7">
        {
          experience.map((item) => (
            <div>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-0.5">
                <p class="font-medium text-ink-primary text-sm">{item.role}</p>
                <p class="text-xs text-ink-secondary shrink-0">{item.when}</p>
              </div>
              <p class="text-xs text-accent mb-2">{item.org}</p>
              <ul class="space-y-1.5">
                {item.bullets.map((b) => (
                  <li class="text-sm text-ink-secondary leading-relaxed pl-4 relative before:content-['–'] before:absolute before:left-0 before:text-border">
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
        <p class="text-xs text-ink-secondary italic">Earlier: {earlier}</p>
      </div>
    </section>

    <!-- Three-column grid for credentials -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-10">

      <!-- Certifications -->
      <section>
        <h2 class="resume-section-heading">Certifications</h2>
        <ul class="space-y-1 text-sm text-ink-primary">
          {certifications.map((c) => (
            <li>
              {credentialUrls[c] ? (
                <a
                  href={credentialUrls[c]}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-accent transition-colors underline underline-offset-2 decoration-border hover:decoration-accent"
                >
                  {c}
                </a>
              ) : c}
            </li>
          ))}
        </ul>
      </section>

      <!-- Awards -->
      <section>
        <h2 class="resume-section-heading">Awards</h2>
        <ul class="space-y-1 text-sm text-ink-secondary">
          {awards.map((a) => <li>{a}</li>)}
        </ul>
      </section>

      <!-- Skills -->
      <section>
        <h2 class="resume-section-heading">Skills</h2>
        <p class="text-sm text-ink-secondary leading-relaxed">{skills}</p>
      </section>

      <!-- Tools -->
      <section>
        <h2 class="resume-section-heading">Tools</h2>
        <p class="text-sm text-ink-secondary leading-relaxed">{tools}</p>
      </section>

      <!-- Selected products -->
      <section>
        <h2 class="resume-section-heading">Selected products</h2>
        <p class="text-sm text-ink-secondary leading-relaxed">{selectedProducts}</p>
      </section>

      <!-- Education & Languages -->
      <section>
        <h2 class="resume-section-heading">Education &amp; Languages</h2>
        <p class="text-sm text-ink-primary font-medium">{educationDegree}</p>
        <p class="text-sm text-ink-secondary mb-2">{educationInstitution}</p>
        <p class="text-sm text-ink-secondary">{languages}</p>
      </section>

    </div>

    <!-- Bottom CTAs -->
    <div class="pt-8 border-t border-border flex flex-wrap gap-4 print:hidden">
      <a href="/portfolio" class="text-sm font-medium text-accent hover:text-accent-dark transition-colors">
        View case studies →
      </a>
      <a href="/#contact" class="text-sm font-medium text-ink-secondary hover:text-ink-primary transition-colors">
        Get in touch →
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .resume-section-heading {
    @apply font-tight font-medium text-xs text-ink-secondary uppercase tracking-wide mb-3 pb-1.5 border-b border-border;
  }

  @media print {
    :global(header),
    :global(footer) {
      display: none !important;
    }
  }
</style>
